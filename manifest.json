{"manifest_version": 3,"name": "CouponHub - Privacy-First Coupon Finder","version": "1.0.0","description": "Find and apply coupons automatically while preserving your privacy","permissions": ["storage","activeTab","scripting","declarativeNetRequest"],"host_permissions": ["https://*/*","http://*/*"],"action": {"default_popup": "src/popup/index.html","default_title": "CouponHub"},"background": {"service_worker": "dist/background.js","type": "module"},"content_scripts": [{"matches": ["https://*/*","http://*/*"],"js": ["dist/content.js"],"run_at": "document_start"}],"icons": {"16": "src/assets/icon-16.png","48": "src/assets/icon-48.png","128": "src/assets/icon-128.png"}}